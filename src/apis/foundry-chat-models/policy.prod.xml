<policies>
  <inbound>
    <base />

    <!--
      ── IP filtering (prod) ───────────────────────────────────────────────────
      Allow-list only — all traffic not listed below is blocked.
    -->
    <ip-filter action="allow">
      <!-- Add allowed IPs/CIDRs here e.g. <address>1.2.3.4</address> -->
    </ip-filter>

    <!--
      ── Rate limiting (prod) ──────────────────────────────────────────────────
      60 calls per minute per subscription key.
    -->
    <rate-limit-by-key
      calls="60"
      renewal-period="60"
      counter-key="@(context.Subscription.Id)"
      remaining-calls-header-name="X-RateLimit-Remaining"
      retry-after-header-name="Retry-After" />

    <!--
      ── Weekly quota ─────────────────────────────────────────────────────────
      Hard cap of 1 000 calls per subscription per rolling 7-day window.
      Prevents runaway consumers from exhausting the OpenAI TPM budget.
    -->
    <quota-by-key
      calls="1000"
      renewal-period="604800"
      counter-key="@(context.Subscription.Id)" />

    <!--
      ── Auth: APIM → Azure OpenAI via managed identity ───────────────────────
      No OpenAI API key ever leaves the gateway.
    -->
    <authentication-managed-identity resource="https://cognitiveservices.azure.com" />

  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-RateLimit-Policy" exists-action="override">
      <value>prod-60rpm-1000pw</value>
    </set-header>
    <!-- Tracing headers -->
    <set-header name="X-Request-Id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
    <set-header name="X-Environment" exists-action="override">
      <value>prod</value>
    </set-header>
    <set-header name="X-Powered-By" exists-action="override">
      <value>L-W Tech AI Gateway</value>
    </set-header>
    <set-header name="Authorization" exists-action="delete" />
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "rate_limit_exceeded",
                message = "Rate limit reached (prod: 60 rpm / 1 000 pw). Check Retry-After header.",
                details = new { subscription = context.Subscription.Id, policy = "prod-60rpm-1000pw" }
              }
            });
          }</set-body>
        </return-response>
      </when>
      <when condition="@(context.Response.StatusCode == 403)">
        <return-response>
          <set-status code="403" reason="Forbidden" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "forbidden",
                message = "Access denied. Your IP address or credentials are not "
                        + "authorised to use this API."
              }
            });
          }</set-body>
        </return-response>
      </when>
    </choose>
  </on-error>
</policies>
