<policies>
  <inbound>
    <base />

    <!--
      ── IP filtering (dev) ───────────────────────────────────────────────────
      Block known bad actors. Add CIDRs below as needed.
    -->
    <ip-filter action="forbid">
      <!-- RFC 5737 documentation ranges — replace with real IPs to block -->
      <address>192.0.2.1</address>
      <address-range from="198.51.100.0" to="198.51.100.255" />
    </ip-filter>

    <!--
      ── Rate limiting (dev) ───────────────────────────────────────────────────
      High ceiling — developers need to iterate quickly without hitting walls.
      No quota; just a soft rate guard to prevent runaway loops.
    -->
    <rate-limit-by-key
      calls="300"
      renewal-period="60"
      counter-key="@(context.Subscription.Id)"
      remaining-calls-header-name="X-RateLimit-Remaining"
      retry-after-header-name="Retry-After" />

    <authentication-managed-identity resource="https://cognitiveservices.azure.com" />

  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-RateLimit-Policy" exists-action="override">
      <value>dev-300rpm</value>
    </set-header>
    <!-- Tracing headers -->
    <set-header name="X-Request-Id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
    <set-header name="X-Environment" exists-action="override">
      <value>dev</value>
    </set-header>
    <set-header name="X-Powered-By" exists-action="override">
      <value>L-W Tech AI Gateway</value>
    </set-header>
    <set-header name="Authorization" exists-action="delete" />
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "rate_limit_exceeded",
                message = "Rate limit reached (dev: 300 rpm). Check Retry-After header.",
                details = new { subscription = context.Subscription.Id, policy = "dev-300rpm" }
              }
            });
          }</set-body>
        </return-response>
      </when>
    </choose>
  </on-error>
</policies>
