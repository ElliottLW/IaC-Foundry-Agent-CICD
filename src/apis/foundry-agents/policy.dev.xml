<policies>
  <inbound>
    <base />

    <!--
      ── IP filtering (dev) ───────────────────────────────────────────────────
      Block known bad actors. Add CIDRs below as needed.
    -->
    <ip-filter action="forbid">
      <!-- RFC 5737 documentation ranges — replace with real IPs to block -->
      <address>192.0.2.1</address>
      <address-range from="198.51.100.0" to="198.51.100.255" />
    </ip-filter>

    <!--
      ── Rate limiting (dev) ───────────────────────────────────────────────────
      Generous limit for local development and CI agent testing.
    -->
    <rate-limit-by-key
      calls="100"
      renewal-period="60"
      counter-key="@(context.Subscription.Id)"
      remaining-calls-header-name="X-RateLimit-Remaining"
      retry-after-header-name="Retry-After" />

    <!--
      ── Foundry Responses API routing ────────────────────────────────────────
      Force the exact api-version required by the AgentEndpoints preview and
      add the feature flag header that activates the stable /endpoint/ path.
    -->
    <set-query-parameter name="api-version" exists-action="override">
      <value>2025-05-15-preview</value>
    </set-query-parameter>

    <set-header name="Foundry-Features" exists-action="override">
      <value>AgentEndpoints=V1Preview</value>
    </set-header>

    <authentication-managed-identity resource="https://ai.azure.com" />

  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-RateLimit-Policy" exists-action="override">
      <value>dev-100rpm</value>
    </set-header>
    <!-- Tracing headers — useful for debugging and demos -->
    <set-header name="X-Request-Id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
    <set-header name="X-Environment" exists-action="override">
      <value>dev</value>
    </set-header>
    <set-header name="X-Powered-By" exists-action="override">
      <value>L-W Tech AI Gateway</value>
    </set-header>
    <!-- Strip Authorization so it never leaks back to the caller -->
    <set-header name="Authorization" exists-action="delete" />
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "rate_limit_exceeded",
                message = "Agent rate limit reached (dev: 100 rpm). Check Retry-After header.",
                details = new { subscription = context.Subscription.Id, policy = "dev-100rpm" }
              }
            });
          }</set-body>
        </return-response>
      </when>
    </choose>
  </on-error>
</policies>
