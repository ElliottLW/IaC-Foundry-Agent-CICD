<policies>
  <inbound>
    <base />

    <!--
      ── Rate limiting (test) ──────────────────────────────────────────────────
      Mirrors prod limits but without the IP block so test runners can call freely.
    -->
    <rate-limit-by-key
      calls="40"
      renewal-period="60"
      counter-key="@(context.Subscription.Id)"
      remaining-calls-header-name="X-RateLimit-Remaining"
      retry-after-header-name="Retry-After" />

    <quota-by-key
      calls="1000"
      renewal-period="604800"
      counter-key="@(context.Subscription.Id)" />

    <set-query-parameter name="api-version" exists-action="skip">
      <value>v1</value>
    </set-query-parameter>

    <authentication-managed-identity resource="https://ai.azure.com" />

  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-RateLimit-Policy" exists-action="override">
      <value>test-40rpm-1000pw</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "rate_limit_exceeded",
                message = "Agent rate limit reached (test: 40 rpm / 1 000 pw). Check Retry-After header.",
                details = new { subscription = context.Subscription.Id, policy = "test-40rpm-1000pw" }
              }
            });
          }</set-body>
        </return-response>
      </when>
    </choose>
  </on-error>
</policies>
