<policies>
  <inbound>
    <base />

    <!--
      ── IP filtering (prod) ───────────────────────────────────────────────────
      Allow-list only — all traffic not listed below is blocked.
    -->
    <ip-filter action="allow">
      <!-- Add allowed IPs/CIDRs here e.g. <address>1.2.3.4</address> -->
    </ip-filter>

    <!--
      ── Rate limiting (prod) ──────────────────────────────────────────────────
      Agent runs are heavier than raw completions — tighter cap than the chat API.
      20 run-initiating calls per minute per subscription key.
    -->
    <rate-limit-by-key
      calls="20"
      renewal-period="60"
      counter-key="@(context.Subscription.Id)"
      remaining-calls-header-name="X-RateLimit-Remaining"
      retry-after-header-name="Retry-After" />

    <!--
      ── Weekly quota ─────────────────────────────────────────────────────────
      250 agent runs per subscription per rolling 7-day window.
    -->
    <quota-by-key
      calls="250"
      renewal-period="604800"
      counter-key="@(context.Subscription.Id)" />

    <!--
      ── Foundry Responses API routing ────────────────────────────────────────
      Token scope is ai.azure.com (not cognitiveservices.azure.com).
    -->
    <set-query-parameter name="api-version" exists-action="override">
      <value>2025-05-15-preview</value>
    </set-query-parameter>

    <set-header name="Foundry-Features" exists-action="override">
      <value>AgentEndpoints=V1Preview</value>
    </set-header>

    <authentication-managed-identity resource="https://ai.azure.com" />

  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-RateLimit-Policy" exists-action="override">
      <value>prod-20rpm-250pw</value>
    </set-header>
    <!-- Tracing headers -->
    <set-header name="X-Request-Id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
    <set-header name="X-Environment" exists-action="override">
      <value>prod</value>
    </set-header>
    <set-header name="X-Powered-By" exists-action="override">
      <value>L-W Tech AI Gateway</value>
    </set-header>
    <set-header name="Authorization" exists-action="delete" />
  </outbound>
  <on-error>
    <base />
    <choose>
      <when condition="@(context.Response.StatusCode == 429)">
        <return-response>
          <set-status code="429" reason="Too Many Requests" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "rate_limit_exceeded",
                message = "Agent run rate limit reached for this subscription. "
                        + "Check the Retry-After header and try again.",
                details = new { subscription = context.Subscription.Id, policy = "prod-20rpm-250pw" }
              }
            });
          }</set-body>
        </return-response>
      </when>
      <when condition="@(context.Response.StatusCode == 403)">
        <return-response>
          <set-status code="403" reason="Forbidden" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>@{
            return Newtonsoft.Json.JsonConvert.SerializeObject(new {
              error = new {
                code    = "forbidden",
                message = "Access denied. Your IP address or credentials are not "
                        + "authorised to use this API."
              }
            });
          }</set-body>
        </return-response>
      </when>
    </choose>
  </on-error>
</policies>
